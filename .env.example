# MQTT broker hostname or IP (required)
MQTT_BROKER=192.168.1.100

# MQTT topic prefix (optional, default: agent)
TOPIC_PREFIX=agent

# Systemd unit to tail (optional, default: homelab-logs)
JOURNAL_UNIT=homelab-logs

# Enable debug logging (optional, default: false)
DEBUG=false

# Log source: "journal" or "docker" (optional, default: journal)
LOG_SOURCE=journal

# Docker container name (required when LOG_SOURCE=docker)
# DOCKER_CONTAINER=mosquitto
