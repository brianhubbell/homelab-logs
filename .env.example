# MQTT broker hostname or IP (required)
MQTT_BROKER=192.168.1.100

# MQTT topic prefix (optional, default: agent)
TOPIC_PREFIX=agent

# Comma-separated list of managed service names (optional, for version reporting)
SERVICES=bt-to-mqtt,wifi-to-mqtt

# System metrics publish interval in seconds (optional, default: 60)
METRICS_INTERVAL_SECONDS=60

# Enable debug logging (optional, default: false)
DEBUG=false
