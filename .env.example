# MQTT broker hostname or IP (required)
MQTT_BROKER=192.168.1.100

# MQTT topic prefix (optional, default: agent)
TOPIC_PREFIX=agent

# Comma-separated whitelist of allowed service names (required)
ALLOWED_SERVICES=govee-to-mqtt,bt-to-mqtt,wifi-to-mqtt

# Comma-separated whitelist of allowed docker compose file paths (optional)
ALLOWED_COMPOSE_PATHS=/opt/homelab/docker-compose.yml

# Health check HTTP port (optional, default: 9110)
HEALTH_PORT=9110

# System metrics publish interval in seconds (optional, default: 60)
METRICS_INTERVAL_SECONDS=60

# Enable debug logging (optional, default: false)
DEBUG=false
